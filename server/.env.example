# Copy to .env for local testing (never commit .env)

# Random secret token — clients must send this as X-Api-Token header.
# Render generates this automatically via render.yaml's generateValue.
API_TOKEN=cambia-questo-con-un-token-segreto

# Port the server listens on (Render sets this automatically)
PORT=10000

# Where Playwright stores the browser profile (cookies, localStorage).
# Must be on the persistent disk when deployed on Render.
PROFILE_DIR=/data/chrome-profile
